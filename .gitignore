*.db
*.sqlite
*.sqlite3

# PostgreSQL
*.dump
*.sql

# Prisma
prisma/dev.db
prisma/migrations/**/migration.sql
!prisma/migrations/migration_lock.toml

# ============================================
# Docker
# ============================================
docker-compose.override.yml
.dockerignore
*.log

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Temporary & Cache Files
# ============================================
*.tmp
*.temp
.tmp/
tmp/
temp/
cache/

# ============================================
# Build Outputs
# ============================================
dist/
build/
out/
*.min.js
*.min.css

# ============================================
# Package Manager Locks (OPTIONAL)
# ============================================
# Uncomment if you want to ignore lock files
# (Not recommended for production projects)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ============================================
# Project-Specific Files
# ============================================

# TLE Data Cache (astronomy service)
astro-service/data/tle-cache/
astro-service/data/*.tle

# Uploaded user files (use S3 in production)
uploads/
user-uploads/
sighting-photos/

# Generated maps/tiles
tiles/
map-cache/

# Processed datasets
datasets/processed/
datasets/downloaded/

# Dark site data (if dynamically generated)
frontend/public/data/dark-sites-generated.json

# Prediction cache (if stored locally)
predictions-cache/

# Export files
exports/
*.csv
*.xlsx
!seed-data/*.csv

# Documentation builds
docs/_build/
docs/.doctrees/

# ============================================
# CI/CD
# ============================================
.github/workflows/*.log

# ============================================
# Monitoring & Analytics
# ============================================
.sentry/
sentry.properties

# ============================================
# Keep These Files (Explicitly)
# ============================================
!.gitkeep
!.env.example
!.github/
!prisma/schema.prisma
!docker-compose.yml

# ============================================
# End of .gitignore
# ============================================