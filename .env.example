# ============================================
# frontend/.env.example
# ============================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to git!

# ============================================
# Application
# ============================================
NEXT_PUBLIC_APP_NAME=Singularity
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Database (PostgreSQL)
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://singularity_user:your_password_here@localhost:5432/singularity_db"

# ============================================
# NextAuth.js (Authentication)
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-here"
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Optional - for Stage 3+)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (Optional - Alternative to Google)
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-secret

# ============================================
# Python Astro Service
# ============================================
ASTRO_SERVICE_URL=http://localhost:8000
ASTRO_SERVICE_API_KEY=dev-key-change-in-production

# ============================================
# External APIs
# ============================================

# OpenWeatherMap (for cloud cover & visibility)
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key

# Mapbox (for maps & routing)
# Get key at: https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# ============================================
# Firebase (for push notifications)
# ============================================
# Get these from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key-for-web-push

# Server-side Firebase Admin SDK
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-app.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# ============================================
# File Storage (Stage 4 - Sighting photos)
# ============================================
# Choose one: AWS S3, Cloudflare R2, or DigitalOcean Spaces

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=singularity-sightings

# OR Cloudflare R2 (S3-compatible, cheaper)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=singularity-sightings

# ============================================
# Redis (for caching - Stage 5+)
# ============================================
REDIS_URL=redis://localhost:6379
# OR for managed Redis (Upstash, Redis Cloud):
# REDIS_URL=rediss://:password@hostname:port

# ============================================
# Email (for notifications fallback)
# ============================================
# Resend (recommended, simple API)
RESEND_API_KEY=re_your_resend_api_key

# OR SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# OR AWS SES
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=your-ses-access-key
AWS_SES_SECRET_KEY=your-ses-secret-key
FROM_EMAIL=noreply@singularity.app

# ============================================
# Monitoring & Analytics
# ============================================
# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Vercel Analytics (if using Vercel)
# Automatically configured on Vercel, no key needed

# Plausible Analytics (privacy-friendly alternative)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=singularity.app

# ============================================
# Development Only
# ============================================
# Skip external API calls (use mocks)
USE_MOCK_APIS=false

# Enable debug logging
DEBUG=false
LOG_LEVEL=info

# Disable auth for local testing (NOT for production!)
DISABLE_AUTH=false

# ============================================
# Production Only
# ============================================
# Set to 'production' in production
NODE_ENV=development

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://singularity.app


# ============================================
# ============================================
# astro-service/.env.example
# ============================================
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# Application
# ============================================
APP_NAME=Singularity Astro Service
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API Server
HOST=0.0.0.0
PORT=8000

# API Security
API_KEY=dev-key-change-in-production
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-for-jwt-or-sessions

# ============================================
# Database (if astro service needs direct access)
# ============================================
# Usually not needed - frontend handles DB
# DATABASE_URL="postgresql://user:pass@localhost:5432/singularity_db"

# ============================================
# Redis (for caching predictions)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600
CACHE_ENABLED=true

# ============================================
# External Data Sources
# ============================================

# Celestrak (TLE data) - No key required
CELESTRAK_BASE_URL=https://celestrak.org
TLE_UPDATE_INTERVAL_HOURS=6

# Space-Track.org (optional, for more TLE sources)
# Register at: https://www.space-track.org/auth/createAccount
SPACETRACK_USERNAME=your-email@example.com
SPACETRACK_PASSWORD=your-spacetrack-password

# N2YO (alternative satellite API)
# Get key at: https://www.n2yo.com/api/
N2YO_API_KEY=your-n2yo-api-key

# ============================================
# Weather APIs
# ============================================
# OpenWeatherMap (same as frontend)
OPENWEATHER_API_KEY=your-openweathermap-api-key

# WeatherAPI.com (alternative)
WEATHERAPI_KEY=your-weatherapi-key

# ============================================
# Light Pollution Data
# ============================================
# Path to VIIRS light pollution dataset (if using local file)
LIGHT_POLLUTION_DATA_PATH=./data/viirs_light_pollution.tif

# OR use LightPollutionMap API
LIGHT_POLLUTION_API_URL=https://api.lightpollutionmap.info

# ============================================
# Astronomy Calculation Settings
# ============================================
# Minimum elevation for visibility (degrees)
MIN_ELEVATION=10

# Maximum number of days to predict ahead
MAX_PREDICTION_DAYS=7

# Default observer elevation (meters above sea level)
DEFAULT_ELEVATION=0

# Sun altitude threshold for darkness (degrees)
SUN_ALTITUDE_THRESHOLD=-12

# ============================================
# Performance & Caching
# ============================================
# Enable calculation caching
ENABLE_CACHE=true

# Cache TTL for predictions (seconds)
PREDICTION_CACHE_TTL=3600

# Worker settings (if using Celery)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================
# CORS (if needed)
# ============================================
CORS_ORIGINS=http://localhost:3000,https://singularity.app

# ============================================
# Monitoring
# ============================================
# Sentry DSN (same project as frontend or separate)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Prometheus metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# Development Settings
# ============================================
# Reload on code changes
RELOAD=true

# Use mock data for testing
USE_MOCK_DATA=false

# Verbose logging for debugging
VERBOSE=true


# ============================================
# ============================================
# docker-compose.override.example.yml
# ============================================
# ============================================
# Copy this to docker-compose.override.yml for local customizations
# This file is ignored by git

version: '3.8'

services:
  postgres:
    environment:
      - POSTGRES_USER=your_custom_user
      - POSTGRES_PASSWORD=your_custom_password
      - POSTGRES_DB=your_custom_db_name
    ports:
      - "5433:5432"  # Use different port if 5432 is taken

  redis:
    ports:
      - "6380:6379"  # Use different port if 6379 is taken


# ============================================
# ============================================
# Setup Instructions
# ============================================
# ============================================

# 1. Frontend Setup
# -----------------
cd frontend
cp .env.example .env.local
# Edit .env.local with your actual values
npm install
npx prisma generate
npx prisma migrate dev

# 2. Astro Service Setup
# ----------------------
cd astro-service
cp .env.example .env
# Edit .env with your actual values
python -m venv venv
source venv/bin/activate  # On Windows: venv\Scripts\activate
pip install -r requirements.txt

# 3. Docker Setup (Database & Redis)
# ----------------------------------
docker-compose up -d

# 4. Generate Secrets
# -------------------
# NEXTAUTH_SECRET:
openssl rand -base64 32

# API_KEY:
openssl rand -hex 32

# 5. Get API Keys (Free Tiers)
# ----------------------------
# OpenWeatherMap: https://openweathermap.org/api
# Mapbox: https://account.mapbox.com
# Firebase: https://console.firebase.google.com
# Sentry: https://sentry.io

# 6. Run Development Servers
# --------------------------
# Terminal 1 - Frontend:
cd frontend && npm run dev

# Terminal 2 - Astro Service:
cd astro-service && uvicorn app.main:app --reload

# Terminal 3 - Database:
docker-compose up

# ============================================
# Quick Start (Minimal Setup)
# ============================================
# For immediate local development, you only need:
# - DATABASE_URL
# - NEXTAUTH_SECRET
# - ASTRO_SERVICE_URL
# 
# Everything else can be added later as you build features!