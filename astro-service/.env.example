# =====================================
# Singularity Astro-Service Environment
# =====================================

# --- Service Metadata ---
ASTRO_SERVICE_NAME=singularity-astro-service
ASTRO_SERVICE_VERSION=0.1.0

# --- Networking ---
HOST=0.0.0.0
PORT=8000

# --- Cache / Prefetch ---
# Hours to cache TLEs before refreshing from Celestrak
TLE_CACHE_TTL_HOURS=6

# --- CORS ---
# Comma-separated list of allowed origins, e.g. https://singularity.app
# Use "*" for local development.
ASTRO_ALLOWED_ORIGINS=*

# --- Logging ---
LOG_LEVEL=INFO

# --- Optional External APIs ---
# Example placeholders if you integrate weather or light-pollution APIs later.
OPENWEATHER_API_KEY=your_openweather_api_key_here
LIGHTPOLLUTION_API_URL=https://example.com/lightpollution

# --- (Optional) Redis / Cache backend ---
# REDIS_URL=redis://redis:6379/0
